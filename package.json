{
  "name": "climatenet-mcp",
  "version": "0.1.0",
  "description": "MCP server for querying ClimateNet environmental monitoring data.",
  "keywords": [
    "air-quality",
    "armenia",
    "climate",
    "climatenet",
    "environmental-data",
    "mcp",
    "model-context-protocol"
  ],
  "homepage": "https://github.com/tom-auger/climatenet-mcp#readme",
  "bugs": {
    "url": "https://github.com/tom-auger/climatenet-mcp/issues"
  },
  "license": "MIT",
  "author": "Tom Auger <tom@tau.gr>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tom-auger/climatenet-mcp.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --noEmit",
    "dev": "tsx src/server.ts",
    "dev:worker": "wrangler dev --port 8788",
    "deploy:worker": "wrangler deploy",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "format": "oxfmt . --check",
    "format:fix": "oxfmt . --write",
    "lint": "oxlint -c oxlint.json .",
    "lint:fix": "oxlint -c oxlint.json . --fix",
    "prepare": "node scripts/prepare.mjs",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:edge": "tsx scripts/edge-smoke.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "agents": "^0.12.0",
    "express": "^5.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260426.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitepress": "^1.6.4",
    "vitepress-plugin-group-icons": "^1.7.5",
    "vitepress-plugin-llms": "^1.12.1",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  },
  "lint-staged": {
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.3+sha512.a19744364a7e248b92657a4ca5973f9354d21caf982579674b1c539f32c7420c47138ad8b1254df07aba9bc782d9b3029e3db34d5dbff974326eb74dac8ff489"
}
